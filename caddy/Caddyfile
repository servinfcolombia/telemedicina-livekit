{
    admin off
    email admin@localhost
    auto_https off
}

# LiveKit WebSocket
livekit.{$DOMAIN}:7888 {
    reverse_proxy localhost:7880
    encode zstd gzip
}

# LiveKit HTTP
livekit-http.{$DOMAIN}:7080 {
    reverse_proxy localhost:7880
    encode zstd gzip
}

# MinIO Console
minio.{$DOMAIN}:9001 {
    reverse_proxy localhost:9001
    encode zstd gzip
}

# MinIO API
minio-api.{$DOMAIN}:9000 {
    reverse_proxy localhost:9000
    encode zstd gzip
}

# PostgreSQL (only via reverse proxy for security)
postgres.{$DOMAIN}:5432 {
    reverse_proxy localhost:5432
}

# Health check endpoint
health.{$DOMAIN}:8080 {
    respond / "OK" 200
    header Access-Control-Allow-Origin "*"
}
